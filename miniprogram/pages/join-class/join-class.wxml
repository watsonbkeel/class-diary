<view class="page">
  <view class="card">
    <view class="title">邀请码加入班级</view>
    <input class="input" placeholder="请输入邀请码" value="{{inviteCode}}" bindinput="handleInviteInput" />
    <button class="btn-primary" loading="{{loading}}" bindtap="queryClass">查询班级</button>
  </view>

  <view wx:if="{{loading}}" class="loading">查询中...</view>
  <view wx:if="{{error}}" class="error">{{error}}</view>

  <view wx:if="{{classInfo}}" class="card">
    <view class="title">{{classInfo.name}}</view>
    <view class="sub-title">{{classInfo.description || '暂无描述'}}</view>
    <textarea class="textarea" placeholder="申请备注（可选）" value="{{message}}" bindinput="handleMessageInput"></textarea>
    <button class="btn-primary" bindtap="submitRequest">申请加入</button>
  </view>
</view>
