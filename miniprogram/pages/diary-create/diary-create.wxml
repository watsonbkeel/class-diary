<view class="page">
  <view class="card">
    <view class="title">写一篇日记</view>
    <textarea class="textarea" placeholder="分享今天的班级故事..." value="{{content}}" bindinput="handleContentInput"></textarea>
    <view class="row-between">
      <view>匿名发布</view>
      <switch checked="{{isAnonymous}}" bindchange="handleAnonymousChange"></switch>
    </view>
    <view class="actions">
      <button class="btn-secondary" disabled="{{loading}}" bindtap="chooseImages">选择图片（最多9张）</button>
    </view>
    <view wx:if="{{localImages.length}}" class="image-grid">
      <view wx:for="{{localImages}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" data-current="{{item}}" bindtap="previewLocalImage"></image>
        <button size="mini" class="btn-danger" disabled="{{loading}}" data-index="{{index}}" bindtap="removeImage">移除</button>
      </view>
    </view>
    <button class="btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="submitDiary">立即发布</button>
  </view>
  <view wx:if="{{loading}}" class="loading">{{uploadingText || '提交中...'}}</view>
  <view wx:if="{{error}}" class="error">{{error}}</view>
</view>
