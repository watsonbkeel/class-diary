page {
  background: #f5f7fb;
  color: #1f2937;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
}

.sub-title {
  color: #64748b;
  font-size: 26rpx;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.btn-primary {
  background: #4f46e5;
  color: #ffffff;
  border-radius: 16rpx;
}

.btn-danger {
  background: #ef4444;
  color: #ffffff;
  border-radius: 16rpx;
}

.btn-secondary {
  background: #e2e8f0;
  color: #1e293b;
  border-radius: 16rpx;
}

.input,
.textarea {
  display: block;
  width: 100%;
  background: #f8fafc;
  border: 2rpx solid #cbd5e1;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  margin-top: 16rpx;
  margin-bottom: 16rpx;
  color: #0f172a;
  font-size: 30rpx;
}

.input {
  min-height: 92rpx;
  line-height: 48rpx;
}

.textarea {
  min-height: 240rpx;
  line-height: 44rpx;
}

.help-list {
  margin-top: 18rpx;
}

.help-item {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
}

.help-index {
  width: 42rpx;
  height: 42rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #eef2ff;
  color: #4338ca;
  text-align: center;
  line-height: 42rpx;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.help-text {
  flex: 1;
  color: #334155;
  line-height: 42rpx;
}

.muted {
  color: #64748b;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4338ca;
  font-size: 22rpx;
}

.empty,
.error,
.loading {
  text-align: center;
  color: #64748b;
  padding: 80rpx 24rpx;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.fab {
  position: fixed;
  right: 30rpx;
  bottom: 40rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #4f46e5;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 16rpx 32rpx rgba(79, 70, 229, 0.28);
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.image-grid image {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
}

.divider {
  height: 1px;
  background: #e2e8f0;
  margin: 20rpx 0;
}
